# Токен Telegram-бота от @BotFather
TELEGRAM_BOT_TOKEN=

# URL backend для контейнера бота (по умолчанию имя сервиса в compose)
BACKEND_BASE_URL=http://backend:8000

# Настройки RunPod API
RUNPOD_API_KEY=
RUNPOD_ENDPOINT_ID=
RUNPOD_BASE_URL=https://api.runpod.ai/v2
RUNPOD_POLL_INTERVAL_SECONDS=8
RUNPOD_REQUEST_TIMEOUT_SECONDS=3600

# Настройки polling бота
BOT_POLL_INTERVAL_SECONDS=8
BOT_STATUS_UPDATE_SECONDS=45
